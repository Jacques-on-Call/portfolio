		<!-- Scripts for interactive components -->
		<script>
			// Mobile Menu Toggle
			const menuBtn = document.getElementById('mobile-menu-btn');
			const mobileMenu = document.getElementById('mobile-menu');

			menuBtn?.addEventListener('click', () => {
				mobileMenu?.classList.toggle('hidden');
			});

			// Hide mobile menu on clicking any link
			const mobileLinks = mobileMenu?.querySelectorAll('a');
			mobileLinks?.forEach(link => {
				link.addEventListener('click', () => {
					mobileMenu?.classList.add('hidden');
				});
			});

			// Contact Form n8n Webhook submission
			const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
			const submitBtn = document.getElementById('submit-btn');
			const successOverlay = document.getElementById('form-status-success');
			const errorOverlay = document.getElementById('form-status-error');
			const resetBtn = document.getElementById('reset-form-btn');
			const errorResetBtn = document.getElementById('error-reset-btn');

			if (contactForm && submitBtn) {
				contactForm.addEventListener('submit', async (e) => {
					e.preventDefault();

					// Visual state: sending
					const originalBtnContent = submitBtn.innerHTML;
					submitBtn.setAttribute('disabled', 'true');
					submitBtn.innerHTML = `
						<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-zinc-950" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<span>SENDING...</span>
					`;

					const formData = new FormData(contactForm);
					const payload = {
						name: formData.get('name'),
						email: formData.get('email'),
						company: formData.get('company') || 'None',
						message: formData.get('message')
					};

					try {
						const response = await fetch('https://n8n.stratgycontent.agency/webhook/portfolio-contact-me-form', {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json'
							},
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							successOverlay?.classList.remove('hidden');
							contactForm.reset();
						} else {
							throw new Error('Server returned error response');
						}
					} catch (error) {
						console.error('Submission error:', error);
						errorOverlay?.classList.remove('hidden');
					} finally {
						// Restore button state
						submitBtn.removeAttribute('disabled');
						submitBtn.innerHTML = originalBtnContent;
					}
				});
			}

			// Reset buttons to return to normal form state
			resetBtn?.addEventListener('click', () => {
				successOverlay?.classList.add('hidden');
			});

			errorResetBtn?.addEventListener('click', () => {
				errorOverlay?.classList.add('hidden');
			});
		</script>
