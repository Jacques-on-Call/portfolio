---
import { Image } from 'astro:assets';
import headshot from '../assets/images/headshot.jpg';

// Import our new beautifully styled creative project screenshots
import projectPremiumSign from '../assets/images/project-premium-sign.png';
import projectFannit from '../assets/images/project-fannit.png';
import projectGreening from '../assets/images/project-greening.png';

// Global stylesheet import
import '../styles/global.css';
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Jacques Damhuis | Creative Content Developer, SEO Strategist & Copywriter</title>
		<!-- Google Fonts for custom tech and warm creative feel -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
		<style>
			body {
				font-family: 'Plus Jakarta Sans', sans-serif;
			}
			.font-serif {
				font-family: 'Playfair Display', serif;
			}
			.font-mono {
				font-family: 'Fira Code', monospace;
			}
		</style>
	</head>
	<body class="bg-zinc-950 text-zinc-100 min-h-screen selection:bg-emerald-500/30 selection:text-emerald-400 overflow-x-hidden antialiased">

		<!-- Subtle ambient background glow -->
		<div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-indigo-950/20 rounded-full blur-[160px] pointer-events-none -z-10"></div>
		<div class="absolute top-[1200px] right-1/4 w-[500px] h-[500px] bg-emerald-950/10 rounded-full blur-[140px] pointer-events-none -z-10"></div>
		<div class="absolute bottom-40 left-1/3 w-[600px] h-[600px] bg-indigo-950/10 rounded-full blur-[160px] pointer-events-none -z-10"></div>

		<!-- Nav Bar -->
		<header class="sticky top-0 z-50 backdrop-blur-md bg-zinc-950/80 border-b border-zinc-900 transition-colors duration-300">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
				<a href="#" class="flex items-center gap-2 group">
					<div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-indigo-500 to-emerald-400 p-[1.5px]">
						<div class="w-full h-full bg-zinc-950 rounded-lg flex items-center justify-center">
							<span class="font-mono text-xs font-bold text-emerald-400 group-hover:text-indigo-400 transition-colors duration-200">JD</span>
						</div>
					</div>
					<span class="font-mono text-sm tracking-tight text-zinc-300 group-hover:text-white transition-colors duration-200">
						jacques-damhuis<span class="text-emerald-400">@</span>portfolio
					</span>
				</a>

				<!-- Desktop Nav Links -->
				<nav class="hidden md:flex items-center gap-8 text-sm">
					<a href="#hero" class="text-zinc-400 hover:text-white hover:underline decoration-emerald-400 decoration-2 underline-offset-4 transition-colors duration-200">Creative Hub</a>
					<a href="#pipeline" class="text-zinc-400 hover:text-white hover:underline decoration-emerald-400 decoration-2 underline-offset-4 transition-colors duration-200">The Blueprint</a>
					<a href="#showcase" class="text-zinc-400 hover:text-white hover:underline decoration-emerald-400 decoration-2 underline-offset-4 transition-colors duration-200">Case Studies</a>
					<a href="#about" class="text-zinc-400 hover:text-white hover:underline decoration-emerald-400 decoration-2 underline-offset-4 transition-colors duration-200">Origin Story</a>
					<a href="#manifesto" class="text-zinc-400 hover:text-white hover:underline decoration-emerald-400 decoration-2 underline-offset-4 transition-colors duration-200">My Manifesto</a>
					<a href="#contact" class="px-4 py-1.5 rounded-md bg-zinc-900 border border-zinc-800 text-zinc-200 hover:text-white hover:bg-zinc-800 hover:border-emerald-500/50 transition-all duration-200">Let's Connect</a>
				</nav>

				<!-- Mobile menu button (simple CSS-based target toggle) -->
				<button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2 rounded hover:bg-zinc-900 text-zinc-400 hover:text-zinc-200 focus:outline-none">
					<span class="w-6 h-0.5 bg-current"></span>
					<span class="w-6 h-0.5 bg-current"></span>
					<span class="w-6 h-0.5 bg-current"></span>
				</button>
			</div>
			<!-- Mobile Nav Menu -->
			<div id="mobile-menu" class="hidden md:hidden border-b border-zinc-900 bg-zinc-950/95 backdrop-blur-md px-4 py-4 space-y-3">
				<a href="#hero" class="block text-zinc-400 hover:text-white text-sm">Creative Hub</a>
				<a href="#pipeline" class="block text-zinc-400 hover:text-white text-sm">The Blueprint</a>
				<a href="#showcase" class="block text-zinc-400 hover:text-white text-sm">Case Studies</a>
				<a href="#about" class="block text-zinc-400 hover:text-white text-sm">Origin Story</a>
				<a href="#manifesto" class="block text-zinc-400 hover:text-white text-sm">My Manifesto</a>
				<a href="#contact" class="block text-zinc-400 hover:text-white text-sm">Let's Connect</a>
			</div>
		</header>

		<!-- Main Page Content -->
		<main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-32">

			<!-- Hero Section -->
			<section id="hero" class="pt-8 md:pt-16 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-7 space-y-6">
					<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-mono">
						<span class="flex h-2 w-2 relative">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
						</span>
						Human Craft, Accelerated Execution
					</div>
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-tight">
						Scaling Big Ideas via <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-emerald-400 bg-clip-text text-transparent">Tech-Enabled Copywriting</span>
					</h1>
					<div class="border-l-2 border-emerald-500 pl-4 space-y-2 py-1">
						<p class="font-serif italic text-lg sm:text-xl text-zinc-300">
							"The Strategy is Deeply Human. The Execution is Accelerated."
						</p>
					</div>
					<p class="text-zinc-400 text-base sm:text-lg max-w-2xl font-light leading-relaxed">
						I craft high-impact B2B white papers, voice-adaptive SEO copy, and multi-channel content engines. I’m an idea person, copywriter, and content manager first. By blending classical creative strategy with modern AI and automation speed-multipliers, I eliminate the operational bottlenecks of content production without ever losing the human soul.
					</p>

					<!-- Stack Tech Badges -->
					<div class="flex flex-wrap gap-2 pt-2 text-xs font-mono text-zinc-400">
						<span class="px-2.5 py-1 rounded bg-zinc-900 border border-zinc-800 text-zinc-300">✍ Brand Storytelling</span>
						<span class="px-2.5 py-1 rounded bg-zinc-900 border border-zinc-800 text-zinc-300">🔍 Semantic SEO & Search Intent</span>
						<span class="px-2.5 py-1 rounded bg-zinc-900 border border-zinc-800 text-zinc-300">⚡ AI Ingest & Ideation Agents</span>
						<span class="px-2.5 py-1 rounded bg-zinc-900 border border-zinc-800 text-zinc-300">🚀 Automated CMS Publishing</span>
					</div>

					<!-- Hero CTAs -->
					<div class="flex flex-col sm:flex-row gap-4 pt-4">
						<a href="#showcase" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-emerald-500 text-zinc-950 hover:bg-emerald-400 text-sm font-semibold transition-all shadow-lg shadow-emerald-500/20 hover:translate-y-[-1px]">
							See Creative Case Studies
						</a>
						<a href="#about" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 text-sm font-semibold transition-all">
							My Origin Story
						</a>
					</div>
				</div>

				<!-- Headshot / Technical Identity card -->
				<div class="lg:col-span-5 flex justify-center">
					<div class="relative w-full max-w-sm group">
						<div class="absolute -inset-1.5 rounded-2xl bg-gradient-to-tr from-indigo-500 to-emerald-500 opacity-25 blur-lg group-hover:opacity-40 transition duration-500"></div>
						<div class="relative bg-zinc-900 border border-zinc-800 rounded-2xl p-6 space-y-6">
							<!-- Header with decorative code controls -->
							<div class="flex items-center justify-between border-b border-zinc-800 pb-4">
								<div class="flex items-center gap-1.5">
									<span class="w-3 h-3 rounded-full bg-red-500/40"></span>
									<span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
									<span class="w-3 h-3 rounded-full bg-green-500/40"></span>
								</div>
								<span class="text-xs font-mono text-zinc-500">jacques-damhuis.config.json</span>
							</div>

							<!-- Bio Details + Profile Pic Headshot wrapper -->
							<div class="flex items-center gap-4">
								<div class="relative w-16 h-16 rounded-xl bg-zinc-800 overflow-hidden border-2 border-emerald-500/40 flex-shrink-0">
									<Image
										src={headshot}
										alt="Jacques Damhuis"
										class="w-full h-full object-cover transition-all duration-300 group-hover:scale-105"
										width={64}
										height={64}
									/>
									<!-- Small offline/online indicator -->
									<span class="absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 border-2 border-zinc-900 rounded-full"></span>
								</div>
								<div>
									<h3 class="font-bold text-white text-lg">Jacques Damhuis</h3>
									<p class="text-sm font-mono text-zinc-500">Creative Content & SEO Manager</p>
								</div>
							</div>

							<!-- Creative Stats inside Card -->
							<div class="grid grid-cols-2 gap-4 bg-zinc-950/50 p-4 rounded-xl border border-zinc-800/80 font-mono text-xs">
								<div>
									<div class="text-zinc-500">Creative Focus</div>
									<div class="text-emerald-400 font-bold text-sm">Ideas & Strategy</div>
								</div>
								<div>
									<div class="text-zinc-500">Tone Adaptation</div>
									<div class="text-indigo-400 font-bold text-sm">Fluid & Compliant</div>
								</div>
								<div>
									<div class="text-zinc-500">B2B Experience</div>
									<div class="text-emerald-400 font-bold text-sm">White Papers / Blogs</div>
								</div>
								<div>
									<div class="text-zinc-500">Tech Multipliers</div>
									<div class="text-indigo-400 font-bold text-sm">n8n / AI Agents</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Interactive SVG System Architecture Diagram -->
			<section id="pipeline" class="space-y-12">
				<div class="text-center max-w-3xl mx-auto space-y-4">
					<h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white">
						The Creative Ingestion & Publishing Pipeline
					</h2>
					<p class="text-zinc-400 font-light text-base sm:text-lg">
						How I design, scale, and deliver elite content from raw concepts to live web-optimized assets instantly.
					</p>
				</div>

				<!-- SVG Core Layout Container -->
				<div class="p-6 md:p-8 bg-zinc-900 border border-zinc-800 rounded-2xl shadow-2xl relative overflow-hidden group">
					<div class="absolute top-0 left-0 px-4 py-2 bg-zinc-950 border-r border-b border-zinc-800 font-mono text-xs text-indigo-400 rounded-tl-xl rounded-br-xl">
						CREATIVE_FLOW_MAP.svg
					</div>

					<div class="w-full pt-8 flex justify-center">
						<!-- Custom stunning SVG Diagram -->
						<svg class="w-full max-w-4xl h-auto" viewBox="0 0 900 360" fill="none" xmlns="http://www.w3.org/2000/svg">
							<!-- Definition of gradients and markers -->
							<defs>
								<linearGradient id="astro-to-cf" x1="0%" y1="0%" x2="100%" y2="0%">
									<stop offset="0%" stop-color="#818cf8" />
									<stop offset="100%" stop-color="#34d399" />
								</linearGradient>
								<linearGradient id="cf-to-n8n" x1="0%" y1="0%" x2="100%" y2="0%">
									<stop offset="0%" stop-color="#34d399" />
									<stop offset="100%" stop-color="#818cf8" />
								</linearGradient>
								<linearGradient id="n8n-to-db" x1="0%" y1="0%" x2="100%" y2="0%">
									<stop offset="0%" stop-color="#818cf8" />
									<stop offset="100%" stop-color="#10b981" />
								</linearGradient>
								<filter id="glow" x="-10%" y="-10%" width="120%" height="120%">
									<feGaussianBlur stdDeviation="6" result="blur" />
									<feComposite in="SourceGraphic" in2="blur" operator="over" />
								</filter>
							</defs>

							<!-- Grid Background for the canvas -->
							<pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
								<path d="M 20 0 L 0 0 0 20" fill="none" stroke="#ffffff" stroke-opacity="0.02" stroke-width="1"/>
							</pattern>
							<rect width="900" height="360" fill="url(#grid)" />

							<!-- Flow lines with animation paths -->
							<path d="M 190 140 H 290" stroke="url(#astro-to-cf)" stroke-width="2" stroke-dasharray="4 4" />
							<path d="M 430 140 H 470" stroke="url(#cf-to-n8n)" stroke-width="2" stroke-dasharray="4 4" />
							<path d="M 610 140 H 710" stroke="url(#n8n-to-db)" stroke-width="2" stroke-dasharray="4 4" />
							<path d="M 540 180 V 240 H 710" stroke="url(#n8n-to-db)" stroke-width="1.5" stroke-dasharray="4 4" />

							<!-- Interactive Hoverable Nodes -->

							<!-- Node 1: Front-End Layers -->
							<g class="cursor-pointer group/node">
								<rect x="30" y="80" width="160" height="120" rx="12" fill="#18181b" stroke="#3f3f46" stroke-width="1.5" class="transition-all duration-300 group-hover/node:stroke-indigo-400 group-hover/node:fill-zinc-900" />
								<rect x="42" y="94" width="24" height="24" rx="6" fill="#818cf8" fill-opacity="0.1" stroke="#818cf8" stroke-width="1.5" />
								<!-- Feather/Pen Icon -->
								<path d="M 48 110 L 58 100 C 60 98 62 98 64 100 C 66 102 66 104 64 106 L 54 116 L 48 116 Z" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
								<line x1="51" y1="113" x2="57" y2="107" stroke="#818cf8" stroke-width="1.5" />

								<text x="78" y="104" fill="#ffffff" font-size="13" font-weight="bold" font-family="'Plus Jakarta Sans', sans-serif">1. Human Idea Hub</text>
								<text x="78" y="118" fill="#a1a1aa" font-size="10" font-family="'Fira Code', monospace">Concept & Strategy</text>

								<text x="42" y="148" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Deep Creative Ideation</text>
								<text x="42" y="162" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Brand-Voice Customization</text>
								<text x="42" y="176" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Narrative Angles & Hooks</text>
							</g>

							<!-- Node 2: Web & CMS Layer -->
							<g class="cursor-pointer group/node">
								<rect x="290" y="80" width="140" height="120" rx="12" fill="#18181b" stroke="#3f3f46" stroke-width="1.5" class="transition-all duration-300 group-hover/node:stroke-emerald-400 group-hover/node:fill-zinc-900" />
								<rect x="302" y="94" width="24" height="24" rx="6" fill="#34d399" fill-opacity="0.1" stroke="#34d399" stroke-width="1.5" />
								<!-- Web/Grid Icon -->
								<rect x="308" y="100" width="12" height="12" rx="2" stroke="#34d399" stroke-width="1.2" fill="none" />
								<line x1="314" y1="100" x2="314" y2="112" stroke="#34d399" stroke-width="1.2" />
								<line x1="308" y1="106" x2="320" y2="106" stroke="#34d399" stroke-width="1.2" />

								<text x="336" y="104" fill="#ffffff" font-size="13" font-weight="bold" font-family="'Plus Jakarta Sans', sans-serif">2. CMS / Web</text>
								<text x="336" y="118" fill="#a1a1aa" font-size="10" font-family="'Fira Code', monospace">WordPress / Astro</text>

								<text x="302" y="148" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Headless API Publishing</text>
								<text x="302" y="162" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Perfect Core Web Vitals</text>
								<text x="302" y="176" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Elegant Web Typography</text>
							</g>

							<!-- Node 3: AI Speed-Multiplier (n8n, Whisper, Claude Code) -->
							<g class="cursor-pointer group/node">
								<rect x="470" y="80" width="140" height="120" rx="12" fill="#18181b" stroke="#818cf8" stroke-width="2" class="transition-all duration-300 group-hover/node:stroke-indigo-400 group-hover/node:fill-zinc-900" filter="url(#glow)" />
								<rect x="482" y="94" width="24" height="24" rx="6" fill="#818cf8" fill-opacity="0.1" stroke="#818cf8" stroke-width="1.5" />
								<!-- Lightning Icon -->
								<path d="M 496 98 L 488 106 H 494 L 492 114 L 500 106 H 494 Z" stroke="#818cf8" stroke-width="1.5" fill="none" stroke-linejoin="round" />

								<text x="516" y="104" fill="#ffffff" font-size="13" font-weight="bold" font-family="'Plus Jakarta Sans', sans-serif">3. Amplifiers</text>
								<text x="516" y="118" fill="#818cf8" font-size="10" font-weight="semibold" font-family="'Fira Code', monospace">n8n / AI Agent</text>

								<text x="482" y="148" fill="#a1a1aa" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Raw Audio Transcribing</text>
								<text x="482" y="162" fill="#34d399" font-size="9" font-weight="bold" font-family="'Fira Code', monospace">● Automated Outlines</text>
								<text x="482" y="176" fill="#a1a1aa" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Instant Formatting Sync</text>
							</g>

							<!-- Node 4: Semrush & Ahrefs (SEO Insights) -->
							<g class="cursor-pointer group/node">
								<rect x="710" y="80" width="160" height="110" rx="12" fill="#18181b" stroke="#3f3f46" stroke-width="1.5" class="transition-all duration-300 group-hover/node:stroke-emerald-400 group-hover/node:fill-zinc-900" />
								<rect x="722" y="94" width="24" height="24" rx="6" fill="#10b981" fill-opacity="0.1" stroke="#10b981" stroke-width="1.5" />
								<!-- Search Icon -->
								<circle cx="732" cy="104" r="4" stroke="#10b981" stroke-width="1.5" />
								<line x1="735" y1="107" x2="741" y2="113" stroke="#10b981" stroke-width="1.5" />

								<text x="756" y="104" fill="#ffffff" font-size="13" font-weight="bold" font-family="'Plus Jakarta Sans', sans-serif">4. SEO Strategy</text>
								<text x="756" y="118" fill="#a1a1aa" font-size="10" font-family="'Fira Code', monospace">Ahrefs & Semrush</text>

								<text x="722" y="144" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Keyword Gap Discovery</text>
								<text x="722" y="158" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Search Intent Mapping</text>
								<text x="722" y="172" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Semantic Topic Clustering</text>
							</g>

							<!-- Node 5: Lead Nurture & Email (Mailchimp) -->
							<g class="cursor-pointer group/node">
								<rect x="710" y="210" width="160" height="110" rx="12" fill="#18181b" stroke="#3f3f46" stroke-width="1.5" class="transition-all duration-300 group-hover/node:stroke-indigo-400 group-hover/node:fill-zinc-900" />
								<rect x="722" y="224" width="24" height="24" rx="6" fill="#818cf8" fill-opacity="0.1" stroke="#818cf8" stroke-width="1.5" />
								<!-- Mail Icon -->
								<rect x="726" y="231" width="16" height="10" rx="2" stroke="#818cf8" stroke-width="1.2" fill="none" />
								<path d="M 726 231 L 734 237 L 742 231" stroke="#818cf8" stroke-width="1.2" />

								<text x="756" y="234" fill="#ffffff" font-size="12" font-weight="bold" font-family="'Plus Jakarta Sans', sans-serif">5. Amplification</text>
								<text x="756" y="248" fill="#a1a1aa" font-size="9" font-family="'Fira Code', monospace">Mailchimp Newsletters</text>

								<text x="722" y="274" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Automated Funnel Flows</text>
								<text x="722" y="288" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● High-Open B2B Copy</text>
								<text x="722" y="302" fill="#71717a" font-size="9" font-family="'Plus Jakarta Sans', sans-serif">● Smart Segment Targeting</text>
							</g>
						</svg>
					</div>

					<!-- Narrative Copy explaining system architecture -->
					<div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 pt-6 border-t border-zinc-800/80">
						<div class="space-y-2">
							<h4 class="font-mono text-xs font-bold text-emerald-400 flex items-center gap-1.5">
								<span class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></span> HUMAN-FIRST STRATEGY
							</h4>
							<p class="text-zinc-400 text-sm font-light leading-relaxed">
								Algorithms don't read content—humans do. I focus my energy on discovering unique industry angles, mastering the specific voice of legal, healthcare, or green energy clients, and creating persuasive arguments that build real authority.
							</p>
						</div>
						<div class="space-y-2">
							<h4 class="font-mono text-xs font-bold text-indigo-400 flex items-center gap-1.5">
								<span class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></span> THE TECH SPEED-MULTIPLIER
							</h4>
							<p class="text-zinc-400 text-sm font-light leading-relaxed">
								Instead of wasting hours on administrative publishing friction, I build custom integrations with tools like n8n and AI agents. From transcribing verbal briefings with Whisper to instantly structuring schemas and routing drafts to WordPress, tech does the busywork so I can create.
							</p>
